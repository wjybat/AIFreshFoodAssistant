# ===== LLM API 配置 =====
# 填入你的 LLM API Key（支持 OpenAI / 智谱GLM / 任何 OpenAI 兼容接口）
LLM_API_KEY=
# API Base URL（OpenAI: https://api.openai.com/v1  智谱GLM: https://open.bigmodel.cn/api/paas/v4 ）
LLM_BASE_URL=https://api.openai.com/v1
# 模型名称（OpenAI 示例: gpt-4o；智谱示例: glm-5.2）
LLM_MODEL=gpt-4o
# auto 会识别 OpenAI、智谱和 OpenCode 官方域名；其他兼容网关按 generic 处理
# 可选：auto / openai / zhipu / opencode / generic / legacy
LLM_PROVIDER=auto
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.7
# GLM-5.2 思考强度；OpenCode Go 仅支持 high / max，其他值取决于供应商
LLM_REASONING_EFFORT=max

# ===== 菜谱图片生成 =====
# 使用参考图 + 每道菜的结构化菜谱调用 OpenAI 兼容 Images Edit 接口。
IMAGE_GENERATION_ENABLED=true
# false 时完整方案不会自动生成图片，只能通过单菜按钮手动触发。
IMAGE_AUTO_GENERATION_ENABLED=false
# true 时任一菜谱图片失败会终止方案保存；默认 false，失败时回退到原有图文菜谱。
IMAGE_GENERATION_REQUIRED=false
IMAGE_API_BASE_URL=http://23.238.4.238:8317/v1
# 留空时复用 LLM_API_KEY；如图片服务使用独立令牌则单独填写。
IMAGE_API_KEY=
IMAGE_MODEL=gpt-image-2
# 部分兼容网关不读取 multipart 中的 model；路由错误时自动追加 ?model=...
IMAGE_MODEL_QUERY_FALLBACK=true
IMAGE_REFERENCE_PATH=assets/recipe-card-reference.png
IMAGE_SIZE=1024x1536
IMAGE_QUALITY=high
IMAGE_TIMEOUT_SECONDS=300
IMAGE_MAX_CONCURRENCY=2
IMAGE_MAX_RESPONSE_BYTES=20000000

# ===== 多步 Agent 与 MCP 经营数据 =====
# 共享开发 MCP fixture 位于：.tmp\AIFreshFoodAssistant-mcp-dev
MCP_ENABLED=false
MCP_SERVER_URL=http://127.0.0.1:8765/mcp
# 远程 MCP 如使用 Bearer 鉴权，在本地 .env 中填写；不要提交真实令牌
MCP_AUTH_TOKEN=
# true：MCP 失败时停止生成且不保存方案；false：回退到请求中的库存数据
MCP_REQUIRED=true
MCP_TIMEOUT_SECONDS=10
MCP_MAX_RESPONSE_BYTES=1000000
AGENT_SALES_WINDOW_DAYS=28
AGENT_MAX_PRODUCTS=100

# ===== 服务器配置 =====
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
# 对外可访问的基础URL（用于生成二维码指向的菜谱页地址；部署到云端时改为实际域名）
SERVER_URL=http://localhost:8000

# ===== 数据与存储路径 =====
DATA_DIR=data
RECIPES_DIR=recipes
MEMORY_DB=memory/memory.db
