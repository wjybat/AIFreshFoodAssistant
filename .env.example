# ===== LLM API 配置 =====
# 填入你的 LLM API Key（支持 OpenAI / 智谱GLM / 任何 OpenAI 兼容接口）
LLM_API_KEY=
# API Base URL（OpenAI: https://api.openai.com/v1  智谱GLM: https://open.bigmodel.cn/api/paas/v4 ）
LLM_BASE_URL=https://api.openai.com/v1
# 模型名称（gpt-4o / glm-4-plus / glm-4-flash 等）
LLM_MODEL=gpt-4o

# ===== 服务器配置 =====
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
# 对外可访问的基础URL（用于生成二维码指向的菜谱页地址；部署到云端时改为实际域名）
SERVER_URL=http://localhost:8000

# ===== 数据与存储路径 =====
DATA_DIR=data
RECIPES_DIR=recipes
MEMORY_DB=memory/memory.db
